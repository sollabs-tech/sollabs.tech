---
import '@fontsource-variable/instrument-sans/wght.css';
import '@fontsource-variable/source-serif-4/wght.css';
import '../styles/global.css';
import {
  brandName,
  repoHref,
  engageHref,
  plausibleDomain,
  projects,
  siteUrl,
} from '../site.config';

interface Props {
  title: string;
  description?: string;
  current?: 'home' | 'outcomes' | 'blog' | 'engage' | 'about';
  ogType?: 'website' | 'article';
  publishedTime?: string;
  structuredData?: Record<string, unknown>[];
}

const {
  title,
  description = 'Sol Labs — outcomes for platform teams.',
  current,
  ogType = 'website',
  publishedTime,
  structuredData = [],
} = Astro.props;

const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
const siteOrigin = Astro.site?.origin ?? siteUrl;
const ogImage = new URL(`${base}og.png`.replace(/\/{2,}/g, '/').replace(':/', '://'), siteOrigin).href;
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteOrigin}/#organization`,
      name: brandName,
      url: `${siteOrigin}/`,
      logo: {
        '@type': 'ImageObject',
        url: `${siteOrigin}/brand/github-avatar-512.png`,
        width: 512,
        height: 512,
      },
      sameAs: [repoHref, projects.kanto.href, projects.pulsys.href, projects.slerp.href],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteOrigin}/#website`,
      name: brandName,
      url: `${siteOrigin}/`,
      publisher: { '@id': `${siteOrigin}/#organization` },
    },
    ...structuredData,
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.js"></script>
    <script is:inline>
      window.plausible =
        window.plausible ||
        function () {
          (window.plausible.q = window.plausible.q || []).push(arguments);
        };
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href={base}>
          <img class="brand__mark" src={`${base}brand/mark.svg`} width="28" height="28" alt="" />
          <span class="brand__word">
            <span class="brand__sol">Sol</span><span class="brand__labs">Labs</span>
          </span>
          <span class="visually-hidden"> home</span>
        </a>
        <nav class="nav" aria-label="Primary">
          <a href={`${base}services/`} aria-current={current === 'services' || current === 'outcomes' ? 'page' : undefined}
            >Services</a
          >
          <a href={`${base}blog/`} aria-current={current === 'blog' ? 'page' : undefined}>Blog</a>
          <a href={`${base}about/`} aria-current={current === 'about' ? 'page' : undefined}>About</a>
          <a
            class="btn btn--primary"
            href={engageHref}
            data-analytics-event="primary_cta_click"
            data-analytics-prop-location="navigation"
          >
            Let's Talk
          </a>
        </nav>
      </div>
    </header>
    <main id="main" class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <div>
          <span class="brand__word">
            <span class="brand__sol">Sol</span><span class="brand__labs">Labs</span>
          </span>
          <p style="margin: 0.5rem 0 0">Google Cloud consulting and engineering.</p>
        </div>
        <div>
          <a href={repoHref}>GitHub</a>
          {' · '}
          <a href={`${base}engage/`}>Engage</a>
          {' · '}
          <span>© {year} {brandName}</span>
        </div>
      </div>
    </footer>
    <script is:inline>
      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element
          ? event.target.closest('[data-analytics-event]')
          : null;
        if (!target) return;

        const props = {};
        for (const attribute of target.attributes) {
          if (!attribute.name.startsWith('data-analytics-prop-')) continue;
          props[attribute.name.replace('data-analytics-prop-', '')] = attribute.value;
        }
        window.plausible?.(target.dataset.analyticsEvent, { props });
      });
    </script>
  </body>
</html>
