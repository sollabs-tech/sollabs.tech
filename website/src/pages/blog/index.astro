---
import Layout from '../../layouts/Layout.astro';
import { posts } from '../../data/posts';
import { brandName, withBase } from '../../site.config';

const platformPosts = posts.filter((post) => post.outcomeSlug !== 'private-vj-inference');
---

<Layout
  title={`Blog · ${brandName}`}
  description="Technical notes for Google Cloud platform leaders: GKE, Zero Trust GitOps, and AI infrastructure."
  current="blog"
>
  <div class="page-wrap">
    <div class="prose" style="max-width: none">
      <h1>Blog</h1>
      <p>Technical field notes on production GCP, GKE delivery, and model infrastructure.</p>
      <ul class="post-list">
        {
          platformPosts.map((post) => (
            <li>
              <a href={withBase(`/blog/${post.slug}/`)}>
                <p class="meta">
                  {post.date} · {post.icp}
                </p>
                <h2>{post.title}</h2>
                <p>{post.description}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</Layout>
