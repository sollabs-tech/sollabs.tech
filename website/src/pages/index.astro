---
/**
 * Homepage hierarchy (Apple Design Award: clarity, one primary goal ≤5s, one job per section):
 * 1. Named offer hero (Zencore slide pattern)
 * 2. The three services
 * 3. Out.Cloud outcome framing (pains → same three services)
 * 4. Customer proof (case studies nested under matching services)
 * 5. How engagements work
 * 6. Final CTA
 */
import Layout from '../layouts/Layout.astro';
import { brandName, engageHref, marketing, withBase } from '../site.config';

const siteOrigin = Astro.site?.origin ?? 'https://sollabs.tech';
const structuredData = [
  {
    '@type': 'ProfessionalService',
    '@id': `${siteOrigin}/#service`,
    name: brandName,
    description: marketing.pageDescription,
    url: `${siteOrigin}/`,
    areaServed: 'Worldwide',
    provider: { '@id': `${siteOrigin}/#organization` },
  },
];

const serviceBySlug = Object.fromEntries(marketing.services.map((s) => [s.slug, s]));
---

<Layout
  title={`${brandName} · Google Cloud consulting & engineering`}
  description={marketing.pageDescription}
  current="home"
  structuredData={structuredData}
>
  <section class="zen-hero zen-hero--static" aria-labelledby="hero-title">
    <div class="zen-hero__bg" aria-hidden="true">
      <canvas class="zen-hero__canvas" data-hero-canvas></canvas>
    </div>
    <div class="zen-hero__inner">
      <h1 id="hero-title" class="zen-hero__title">{marketing.heroTitle}</h1>
      <p class="zen-hero__lead">{marketing.heroLead}</p>
      <div class="zen-hero__cta-row">
        <a
          class="btn btn--primary btn--lg"
          href={engageHref}
          data-analytics-event="primary_cta_click"
          data-analytics-prop-location="hero"
        >
          {marketing.heroPrimaryCta}
        </a>
        <a
          class="btn btn--ghost btn--lg"
          href={withBase(marketing.heroSecondaryHref)}
          data-analytics-event="service_view"
          data-analytics-prop-service={marketing.heroTitle}
        >
          {marketing.heroSecondaryCta}
        </a>
      </div>
    </div>
  </section>

  <div class="lp">
    <!-- PRIMARY: Our services — one card per offer (pain + Learn more). No second row. -->
    <section class="lp-section" id="capabilities" aria-labelledby="capabilities-title">
      <h2 id="capabilities-title" class="lp-section-title">{marketing.capabilitiesTitle}</h2>
      <div class="challenge-grid">
        {
          marketing.challenges.map((c) => {
            const service = serviceBySlug[c.serviceSlug];
            return (
              <a
                class="challenge-item challenge-item--link"
                href={withBase(service.href)}
                data-analytics-event="service_view"
                data-analytics-prop-service={service.title}
              >
                <p class="challenge-item__service">{service.title}</p>
                <h3>{c.title}</h3>
                <p>{c.body}</p>
                <span class="challenge-item__more">Learn more</span>
              </a>
            );
          })
        }
      </div>
    </section>

    <!-- TERTIARY: Labs — Sol Labs' own builds (not client work) -->
    <section class="lp-section" aria-labelledby="proof-title">
      <h2 id="proof-title" class="lp-section-title">{marketing.caseStudiesTitle}</h2>
      <div class="proof-grid">
        {
          marketing.caseStudies.map((caseStudy) => (
            <article class="proof-card">
              <a
                class="proof-card__image"
                href={withBase(caseStudy.href)}
                data-analytics-event="proof_view"
                data-analytics-prop-case-study={caseStudy.name}
              >
                <picture>
                  <source
                    type="image/webp"
                    srcset={`${withBase(caseStudy.image.replace('.webp', '-640.webp'))} 640w, ${withBase(caseStudy.image)} 1280w`}
                    sizes="(max-width: 899px) 100vw, 33vw"
                  />
                  <img
                    src={withBase(caseStudy.image)}
                    alt={caseStudy.alt}
                    width="1280"
                    height="800"
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
              </a>
              <div class="proof-card__body">
                <p class="proof-card__product">
                  {marketing.caseStudyKind} · {caseStudy.name} · {caseStudy.area}
                </p>
                <h3>{caseStudy.title}</h3>
                <p>{caseStudy.body}</p>
                <a
                  href={withBase(caseStudy.href)}
                  data-analytics-event="proof_view"
                  data-analytics-prop-case-study={caseStudy.name}
                >
                  {marketing.caseStudyCta}
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="lp-section" aria-labelledby="method-title">
      <h2 id="method-title" class="lp-section-title">{marketing.methodTitle}</h2>
      <ol class="method-list">
        {
          marketing.methodSteps.map((step) => (
            <li>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="lp-final" aria-labelledby="final-title">
      <h2 id="final-title" class="lp-section-title">{marketing.finalCtaHeadline}</h2>
      <p class="lp-section-lead">{marketing.finalCtaLead}</p>
      <a
        class="btn btn--primary btn--lg"
        href={engageHref}
        data-analytics-event="primary_cta_click"
        data-analytics-prop-location="home_final"
      >
        {marketing.finalPrimaryCta}
      </a>
    </section>
  </div>
</Layout>

<script>
  import { initHero } from '../scripts/hero-webgl';
  initHero();
</script>
