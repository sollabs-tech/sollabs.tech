---
import Layout from '../layouts/Layout.astro';
import { brandName, engageHref, marketing, withBase } from '../site.config';
---

<Layout
  title={`About · ${brandName}`}
  description={marketing.pageDescription}
  current="about"
>
  <div class="page-wrap">
    <div class="prose">
      <p class="meta">{marketing.categoryEyebrow}</p>
      <h1>{brandName}</h1>
      <!-- Zencore firm positioning (name swap) -->
      <p>
        {brandName} is a Google Cloud consulting and engineering firm. We offer implementation and
        operational services across platform engineering, GKE security, and AI infrastructure.
      </p>
      <h2>{marketing.capabilitiesTitle}</h2>
      <ul>
        {
          marketing.services.map((s) => (
            <li>
              <a href={withBase(s.href)}>{s.title}</a> — {s.body}
            </li>
          ))
        }
      </ul>

      <a
        class="btn btn--primary btn--lg"
        href={engageHref}
        data-analytics-event="primary_cta_click"
        data-analytics-prop-location="about"
      >
        {marketing.primaryCta}
      </a>
    </div>
  </div>
</Layout>
