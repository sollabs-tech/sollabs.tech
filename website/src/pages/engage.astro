---
import Layout from '../layouts/Layout.astro';
import { brandName, contactEmail, marketing } from '../site.config';
---

<Layout
  title={`Engage · ${brandName}`}
  description="Talk to Sol Labs about Google Cloud platform, AI infrastructure, or secure delivery."
  current="engage"
>
  <div class="page-wrap">
    <div class="prose">
      <h1>Tell us what is blocking production.</h1>
      <p>
        Discovery is short. If there is a fit, you get a fixed statement of work with a done
        definition — not an open retainer by default.
      </p>

      <h2>Good fits</h2>
      <ul>
        <li>GCP platform / GKE / GitOps that needs to be operable</li>
        <li>AI inference fleets burning time on model pulls and Hub dependency</li>
        <li>Secure delivery wired into how you ship — not bolted on for a deal</li>
      </ul>

      <p>{marketing.clarityLine}</p>

      <h2>Book</h2>
      <p>
        <a href={`mailto:${contactEmail}?subject=Sol%20Labs%20discovery`}>{contactEmail}</a>
      </p>
      <a class="btn btn--primary btn--lg" href={`mailto:${contactEmail}?subject=Sol%20Labs%20discovery`}
        >Email to talk</a
      >
    </div>
  </div>
</Layout>