---
import Layout from '../layouts/Layout.astro';
import { brandName, calUrl, contactEmail, marketing } from '../site.config';

const emailHref = `mailto:${contactEmail}?subject=Sol%20Labs%20Google%20Cloud`;
let calLink = '';
try {
  const parsed = new URL(calUrl);
  if (parsed.hostname === 'cal.com' || parsed.hostname.endsWith('.cal.com')) {
    calLink = parsed.pathname.replace(/^\/|\/$/g, '');
  }
} catch {
  // PUBLIC_CAL_URL is optional; email remains a working fallback.
}
---

<Layout
  title={`Contact Us · ${brandName}`}
  description="Contact Us. Ready to get started?"
  current="engage"
>
  <div class="page-wrap">
    <div class="prose">
      <!-- Zencore /lets-talk -->
      <p class="meta">Get In Touch</p>
      <h1>Contact Us</h1>
      <p>Ready to get started?</p>
      <p>Our initial consultation is an understanding of your business and objectives.</p>

      <!-- Out.Cloud -->
      <p>
        30 minutes. No slides. Just an honest conversation about where you are and what it would
        take to get you there.
      </p>
      <p>{marketing.clarityLine}</p>

      {
        calLink ? (
          <>
            <h2 id="calendar">Let's Talk</h2>
            <div
              id="cal-inline"
              class="cal-embed"
              aria-label="Let's Talk — Sol Labs Google Cloud"
            />
            <p class="booking-fallback">
              Calendar not loading?{' '}
              <a href={calUrl} data-analytics-event="cal_open" rel="noopener noreferrer">
                Open Cal.com
              </a>
              {' or '}
              <a href={emailHref}>email {contactEmail}</a>.
            </p>
            <script is:inline define:vars={{ calLink }}>
              (function (C, A, L) {
                const push = (target, args) => target.q.push(args);
                const document = C.document;
                C.Cal =
                  C.Cal ||
                  function () {
                    const cal = C.Cal;
                    const args = arguments;
                    if (!cal.loaded) {
                      cal.ns = {};
                      cal.q = cal.q || [];
                      const script = document.createElement('script');
                      script.src = A;
                      document.head.appendChild(script);
                      cal.loaded = true;
                    }
                    if (args[0] === L) {
                      push(cal, args);
                      return;
                    }
                    push(cal, args);
                  };
              })(window, 'https://app.cal.com/embed/embed.js', 'init');

              Cal('init', { origin: 'https://cal.com' });
              Cal('on', {
                action: 'bookingSuccessfulV2',
                callback: () => window.plausible?.('booking_complete'),
              });
              Cal('inline', {
                elementOrSelector: '#cal-inline',
                calLink,
                config: { layout: 'month_view', theme: 'light' },
              });
              window.plausible?.('cal_open', { props: { location: 'engage_embed' } });
            </script>
          </>
        ) : (
          <>
            <h2>Let's Talk</h2>
            <p>
              Calendar availability is being configured. Email the blocker and preferred timezone;
              we will reply with times.
            </p>
            <a
              class="btn btn--primary btn--lg"
              href={emailHref}
              data-analytics-event="cal_open"
              data-analytics-prop-location="engage_email_fallback"
            >
              Get in Touch
            </a>
          </>
        )
      }
    </div>
  </div>
</Layout>
